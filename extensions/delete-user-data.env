# Config for the firebase/delete-user-data extension (instance: delete-user-data).
# Fires on Firebase Auth account deletion (incl. the iOS client's
# Auth.auth().currentUser.delete()) and removes the per-uid server data.
# Deploy with: firebase deploy --only extensions

# Delete the per-user rate-limit doc. {UID} is substituted with the deleted uid.
FIRESTORE_PATHS=rateLimits/{UID}

# The rateLimits doc has no subcollections, so a shallow delete is sufficient.
FIRESTORE_DELETE_MODE=shallow

# Only delete the explicit path above — no auto-discovery, no RTDB/Storage/search.
ENABLE_AUTO_DISCOVERY=no
RTDB_PATHS=
STORAGE_PATHS=
SEARCH_FUNCTION=
